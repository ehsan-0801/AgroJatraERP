# ── Server ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (the frontend dev server)
CORS_ORIGIN=http://localhost:5173

# ── Database (Supabase PostgreSQL) ──────────────────────────────────
# Direct (non-pooling) connection — used by the API server and migrations.
DATABASE_URL="postgres://postgres.<ref>:<password>@<host>:5432/postgres?sslmode=require"
# Transaction pooler (pgbouncer) — optional, for serverless deployments.
DATABASE_POOL_URL="postgres://postgres.<ref>:<password>@<host>:6543/postgres?sslmode=require&pgbouncer=true"

# ── Supabase ────────────────────────────────────────────────────────
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
SUPABASE_JWT_SECRET="<jwt-secret>"
